# PlateNudge AI Photo Mode (optional feature)
#
# These are SERVER-SIDE variables only. NEVER prefix them with VITE_ — that
# would expose them to the browser bundle. Set them in:
#   Vercel → Project → Settings → Environment Variables
# (For local AI testing run `vercel dev`; plain `vite dev`/`preview` does not
#  run the /api functions and AI Photo Mode will show its "unavailable" state.)

# --- Required for AI Photo Mode (set the provider key(s) you use) ---
OPENROUTER_API_KEY=
GROQ_API_KEY=

# --- Optional: override the pinned default models (src/ai-config.js) ---
# If unset/blank, the built-in defaults below are used automatically:
#   OPENROUTER_MODEL  default = openai/gpt-4o-mini
#   GROQ_VISION_MODEL default = meta-llama/llama-4-scout-17b-16e-instruct
OPENROUTER_MODEL=
GROQ_VISION_MODEL=

# --- Optional: OpenRouter attribution header (your deployed URL) ---
PUBLIC_SITE_URL=
